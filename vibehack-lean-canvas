<title>VibeHack — Lean Canvas</title>
<link href="./VibeHack — Lean Canvas_files/css2" rel="stylesheet">
<style>
  /* ─── TOKENS ─────────────────────────────────────────────── */
  :root {
    --navy:        #0A0A1F;
    --navy-box:    #0E0E28;
    --navy-hi:     #1A0830;
    --pink:        #F005FF;
    --pink-dim:    rgba(240,5,255,.15);
    --blue:        #0884F6;
    --cyan:        #13CBFF;
    --white:       #F5F5F5;
    --gray:        #6a6a9a;
    --dim:         #3a3a66;
    --border:      #1e1e44;
    --border-hi:   #F005FF;
    --font-title:  'Orbitron', monospace;
    --font-body:   'Figtree', sans-serif;
  }

  /* ─── RESET ──────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ─── PAGE ───────────────────────────────────────────────── */
  html, body {
    height: 100%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 13px;
  }

  body {
    display: flex;
    flex-direction: column;
    padding: 14px 18px 12px;
    gap: 8px;
    min-height: 100vh;
  }

  /* ─── GRADIENT BAR ───────────────────────────────────────── */
  .grad-bar {
    height: 3px;
    background: linear-gradient(to right, #F005FF, #0884F6, #13CBFF);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ─── HEADER ─────────────────────────────────────────────── */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .header-left { display: flex; align-items: baseline; gap: 12px; }

  .logo {
    font-family: var(--font-title);
    font-size: 16px;
    font-weight: 900;
    letter-spacing: 4px;
    background: linear-gradient(to right, #F005FF, #0884F6, #13CBFF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .doc-title {
    font-family: var(--font-title);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 3px;
    color: var(--gray);
    text-transform: uppercase;
  }

  .header-right {
    display: flex;
    gap: 24px;
  }

  .field {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .field-label {
    font-family: var(--font-title);
    font-size: 7px;
    letter-spacing: 2px;
    color: var(--gray);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .field-input {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--white);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--dim);
    outline: none;
    width: 140px;
    padding: 1px 3px;
    transition: border-color .15s;
  }
  .field-input:focus { border-bottom-color: var(--pink); }
  .field-input::placeholder { color: var(--dim); font-style: italic; }

  /* ─── CANVAS ─────────────────────────────────────────────── */
  .canvas {
    flex: 1;
    display: grid;
    /*  10 equal columns → clean 50/50 cost/revenue split  */
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows: 2.1fr 1.4fr 0.68fr;
    border: 1.5px solid var(--border);
    min-height: 0;
  }

  /* ─── BOX ────────────────────────────────────────────────── */
  .box {
    border: 1px solid var(--border);
    background: var(--navy-box);
    padding: 9px 11px 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    transition: background .15s;
  }

  .box.hi {
    background: var(--navy-hi);
    border: 1.5px solid var(--border-hi);
    box-shadow: inset 0 0 22px rgba(240,5,255,.06);
  }

  /* ─── GRID PLACEMENT ─────────────────────────────────────── */
  #problem   { grid-column: 1 / 3;  grid-row: 1 / 3; }
  #solution  { grid-column: 3 / 5;  grid-row: 1 / 2; }
  #uvp       { grid-column: 5 / 7;  grid-row: 1 / 3; }
  #unfair    { grid-column: 7 / 9;  grid-row: 1 / 2; }
  #customers { grid-column: 9 / 11; grid-row: 1 / 3; }
  #metrics   { grid-column: 3 / 5;  grid-row: 2 / 3; }
  #channels  { grid-column: 7 / 9;  grid-row: 2 / 3; }
  #cost      { grid-column: 1 / 6;  grid-row: 3 / 4; }
  #revenue   { grid-column: 6 / 11; grid-row: 3 / 4; }

  /* ─── BOX HEADER ─────────────────────────────────────────── */
  .bh { flex-shrink: 0; }

  .btitle {
    font-family: var(--font-title);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--white);
    line-height: 1.2;
  }
  .hi .btitle { color: var(--pink); }

  .bsub {
    font-size: 9.5px;
    font-style: italic;
    color: var(--gray);
    margin-top: 2px;
    line-height: 1.35;
  }

  /* ─── FILL BADGES ────────────────────────────────────────── */
  .badge-now {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 4px;
    font-family: var(--font-title);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--pink);
    background: var(--pink-dim);
    border: 1px solid var(--pink);
    padding: 2px 6px 1px;
    border-radius: 2px;
    width: fit-content;
  }

  .badge-later {
    display: inline-block;
    margin-top: 3px;
    font-size: 9px;
    font-style: italic;
    color: var(--dim);
  }

  /* ─── EDITABLE CONTENT AREA ──────────────────────────────── */
  .bcontent {
    flex: 1;
    margin-top: 6px;
    padding: 4px 3px;
    outline: none;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--white);
    line-height: 1.55;
    caret-color: var(--pink);
    border-radius: 2px;
    min-height: 0;
    overflow-y: auto;
    transition: background .12s;
    word-break: break-word;
  }

  .bcontent:focus {
    background: rgba(255,255,255,.025);
  }

  .bcontent:empty::before {
    content: attr(data-ph);
    color: var(--dim);
    font-style: italic;
    pointer-events: none;
  }

  /* ─── SUB-SECTION (Existing Alt / High-Level / Early Adopters) ─ */
  .sub {
    flex-shrink: 0;
    margin-top: 6px;
    padding-top: 7px;
    border-top: 1px solid var(--border);
  }
  .hi .sub { border-top-color: rgba(240,5,255,.25); }

  .stitle {
    font-family: var(--font-title);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gray);
    line-height: 1.2;
  }
  .hi .stitle { color: rgba(240,5,255,.65); }

  .ssub {
    font-size: 9px;
    font-style: italic;
    color: var(--dim);
    margin-top: 1px;
    line-height: 1.3;
  }

  .scontent {
    margin-top: 4px;
    padding: 3px;
    outline: none;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--white);
    line-height: 1.5;
    caret-color: var(--pink);
    min-height: 34px;
    max-height: 70px;
    overflow-y: auto;
    border-radius: 2px;
    transition: background .12s;
    word-break: break-word;
  }

  .scontent:focus { background: rgba(255,255,255,.025); }

  .scontent:empty::before {
    content: attr(data-ph);
    color: var(--dim);
    font-style: italic;
    pointer-events: none;
  }

  /* ─── FOOTER ─────────────────────────────────────────────── */
  .footer {
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 8px;
    color: var(--dim);
    letter-spacing: .5px;
  }

  .footer span:nth-child(2) {
    color: var(--cyan);
    font-style: italic;
  }

  /* ─── PRINT ──────────────────────────────────────────────── */
  @media print {
    @page { size: A4 landscape; margin: 8mm; }

    body {
      background: #fff;
      color: #111;
      padding: 0;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .logo { -webkit-text-fill-color: #F005FF; color: #F005FF; }
    .box { background: #fff !important; box-shadow: none; }
    .box.hi { background: #fdf0ff !important; border-color: #F005FF !important; }
    .bcontent, .scontent { color: #111; font-size: 10px; }
    .bsub, .ssub, .badge-later, .footer { color: #888; }
    .grad-bar { print-color-adjust: exact; }
  }
</style>
</head>
